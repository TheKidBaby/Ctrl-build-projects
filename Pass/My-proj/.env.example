# VaultMaster Frontend Configuration

# Backend API URL
# For local development: http://localhost:3001/api/vault
# For production: https://your-domain.com/api/vault
VITE_API_URL=http://localhost:3001/api/vault

# Feature flags
VITE_ENABLE_BACKEND_SYNC=true
VITE_AUTO_SYNC_ENABLED=true
VITE_AUTO_SYNC_INTERVAL=300000

# Environment
VITE_APP_ENV=development
